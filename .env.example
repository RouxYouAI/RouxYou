# ============================================================
# RouxYou — Secrets Template
# Copy this file to .env and fill in your values.
# .env is excluded from git — NEVER commit it.
# ============================================================

# Anthropic API key (only needed if using Claude as Big Brain / Phase 31)
# Leave blank for fully local operation.
ANTHROPIC_API_KEY=

# Home Assistant long-lived access token
# Generate one at: HA > Profile > Long-Lived Access Tokens
HA_TOKEN=

# Remote server password (only if using remote server monitoring — e.g. Proxmox, TrueNAS)
REMOTE_SERVER_PASSWORD=
